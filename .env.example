# Azure AD app registration — required for Microsoft Graph email sending
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# The licensed mailbox to send emails FROM (must be a real mailbox, not an alias)
GRAPH_FROM_EMAIL=noreply@yourdomain.com

# Inbox that receives inquiries (defaults to info@collegeproduce.com if not set)
CONTACT_TO_EMAIL=info@collegeproduce.com

# Server port (optional, defaults to 3001)
PORT=3001
